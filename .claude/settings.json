{
  "permissions": {
    "allow": [
      "Bash(npx expo *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx vitest *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(npx expo publish *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
